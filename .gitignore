# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scratch files
scratch/

# SharePoint vendor migration working data (contains extracted TINs, bank info, raw docs)
/sharepoint-import-work/

# supabase local CLI metadata
supabase/.temp/

# AI agent compiled artifacts
.agents/

# opencode AI workspace metadata
.opencode/

# Playwright capture session token (user guide)
scripts/.auth.json
